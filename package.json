{
  "name": "bolt-wizard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BoltWizard — in-browser full-stack AI dev agent. Build, run, and preview real apps with a local-first WebContainer + multi-provider LLM.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node tests/smoke.mjs",
    "watch": "node scripts/watch.js --lint --test",
    "diagnose:layout": "node scripts/diagnose-layout.mjs",
    "render:pipeline": "node scripts/render-pipeline.mjs",
    "live:run": "node scripts/live-run.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@webcontainer/api": "^1.5.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
